{
  "realm": "book-review",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "sslRequired": "none",
  "accountTheme": "keycloak.v2",
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular user role",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Admin role for review moderation",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "book-review-web",
      "name": "Book Review Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "https://bookreview.ge/*"],
      "webOrigins": ["http://localhost:3000", "https://bookreview.ge"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "basic", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "organization", "microprofile-jwt"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "book-review-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "book-review-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "book-review-api",
      "name": "Book Review API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "basic", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "organization", "microprofile-jwt"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${KC_GOOGLE_CLIENT_ID:disabled}",
        "clientSecret": "${KC_GOOGLE_CLIENT_SECRET:disabled}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "facebook",
      "providerId": "facebook",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${KC_FACEBOOK_CLIENT_ID:disabled}",
        "clientSecret": "${KC_FACEBOOK_CLIENT_SECRET:disabled}",
        "defaultScope": "email,public_profile",
        "syncMode": "IMPORT"
      }
    }
  ],
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@bookreview.local",
    "fromDisplayName": "Book Review",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  }
}
