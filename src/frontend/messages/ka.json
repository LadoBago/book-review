  "privacy": {
    "title": "\u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d8\u10e1 \u10de\u10dd\u10da\u10d8\u10e2\u10d8\u10d9\u10d0",
    "lastUpdated": "\u10d1\u10dd\u10da\u10dd\u10e1 \u10d2\u10d0\u10dc\u10d0\u10ee\u10da\u10d4\u10d1\u10d0: 29 \u10db\u10d0\u10e0\u10e2\u10d8, 2026",
    "sections": {
      "overview": {
        "title": "\u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d0",
        "body": "\u10ec\u10d8\u10d2\u10dc\u10d8\u10e1 \u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d0 (bookreview.ge) \u10d0\u10e0\u10d8\u10e1 \u10de\u10da\u10d0\u10e2\u10e4\u10dd\u10e0\u10db\u10d0 \u10ec\u10d8\u10d2\u10dc\u10d8\u10e1 \u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d4\u10d1\u10d8\u10e1 \u10e8\u10d4\u10e1\u10d0\u10e5\u10db\u10dc\u10d4\u10da\u10d0\u10d3 \u10d3\u10d0 \u10d2\u10d0\u10e1\u10d0\u10d6\u10d8\u10d0\u10e0\u10d4\u10d1\u10d4\u10da\u10d0\u10d3. \u10e9\u10d5\u10d4\u10dc \u10d5\u10d0\u10da\u10d3\u10d4\u10d1\u10e3\u10da\u10d4\u10d1\u10d8 \u10d5\u10d0\u10e0\u10d7 \u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d8\u10e1 \u10d3\u10d0\u10ea\u10d5\u10d0\u10e1. \u10d4\u10e1 \u10de\u10dd\u10da\u10d8\u10e2\u10d8\u10d9\u10d0 \u10d2\u10d0\u10dc\u10db\u10d0\u10e0\u10e2\u10d0\u10d5\u10e1, \u10e0\u10d0 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10e1 \u10d5\u10d0\u10d2\u10e0\u10dd\u10d5\u10d4\u10d1\u10d7, \u10e0\u10dd\u10d2\u10dd\u10e0 \u10d5\u10d8\u10e7\u10d4\u10dc\u10d4\u10d1\u10d7 \u10db\u10d0\u10e1 \u10d3\u10d0 \u10e0\u10d0 \u10e3\u10e4\u10da\u10d4\u10d1\u10d4\u10d1\u10d8 \u10d2\u10d0\u10e5\u10d5\u10d7."
      },
      "dataCollected": {
        "title": "\u10e0\u10d0 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10e1 \u10d5\u10d0\u10d2\u10e0\u10dd\u10d5\u10d4\u10d1\u10d7",
        "intro": "\u10e9\u10d5\u10d4\u10dc \u10d5\u10d0\u10d2\u10e0\u10dd\u10d5\u10d4\u10d1\u10d7 \u10e8\u10d4\u10db\u10d3\u10d4\u10d2 \u10d8\u10dc\u10e4\u10dd\u10e0\u10db\u10d0\u10ea\u10d8\u10d0\u10e1:",
        "items": {
          "account": "\u10d0\u10dc\u10d2\u10d0\u10e0\u10d8\u10e8\u10d8\u10e1 \u10d8\u10dc\u10e4\u10dd\u10e0\u10db\u10d0\u10ea\u10d8\u10d0: \u10e1\u10d0\u10ee\u10d4\u10da\u10d8 \u10d3\u10d0 \u10d4\u10da\u10e4\u10dd\u10e1\u10e2\u10d0, \u10e0\u10dd\u10db\u10d4\u10da\u10e1\u10d0\u10ea \u10db\u10d8\u10e3\u10d7\u10d8\u10d7\u10d4\u10d1\u10d7 \u10e0\u10d4\u10d2\u10d8\u10e1\u10e2\u10e0\u10d0\u10ea\u10d8\u10d8\u10e1\u10d0\u10e1 \u10d0\u10dc \u10e1\u10dd\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10d8 \u10d0\u10d5\u10e2\u10dd\u10e0\u10d8\u10d6\u10d0\u10ea\u10d8\u10d8\u10d7 (Google, Facebook).",
          "content": "\u10d7\u10e5\u10d5\u10d4\u10dc \u10db\u10d8\u10d4\u10e0 \u10e8\u10d4\u10e5\u10db\u10dc\u10d8\u10da\u10d8 \u10d9\u10dd\u10dc\u10e2\u10d4\u10dc\u10e2\u10d8: \u10ec\u10d8\u10d2\u10dc\u10d8\u10e1 \u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d4\u10d1\u10d8, \u10ea\u10d8\u10e2\u10d0\u10e2\u10d4\u10d1\u10d8 \u10d3\u10d0 \u10d0\u10e2\u10d5\u10d8\u10e0\u10d7\u10e3\u10da\u10d8 \u10e1\u10e3\u10e0\u10d0\u10d7\u10d4\u10d1\u10d8.",
          "technical": "\u10e2\u10d4\u10e5\u10dc\u10d8\u10d9\u10e3\u10e0\u10d8 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10d8: IP \u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8, \u10d1\u10e0\u10d0\u10e3\u10d6\u10d4\u10e0\u10d8\u10e1 \u10e2\u10d8\u10de\u10d8 \u10d3\u10d0 \u10db\u10dd\u10dc\u10d0\u10ee\u10e3\u10da\u10d4\u10d1\u10e3\u10da\u10d8 \u10d2\u10d5\u10d4\u10e0\u10d3\u10d4\u10d1\u10d8, \u10e0\u10dd\u10db\u10d4\u10da\u10d8\u10ea \u10d0\u10d5\u10e2\u10dd\u10db\u10d0\u10e2\u10e3\u10e0\u10d0\u10d3 \u10d2\u10e0\u10dd\u10d5\u10d3\u10d4\u10d1\u10d0 \u10e3\u10e1\u10d0\u10e4\u10e0\u10d7\u10ee\u10dd\u10d4\u10d1\u10d8\u10e1\u10d0 \u10d3\u10d0 \u10e1\u10d4\u10e0\u10d5\u10d8\u10e1\u10d8\u10e1 \u10e4\u10e3\u10dc\u10e5\u10ea\u10d8\u10dd\u10dc\u10d8\u10e0\u10d4\u10d1\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1."
        }
      },
      "usage": {
        "title": "\u10e0\u10dd\u10d2\u10dd\u10e0 \u10d5\u10d8\u10e7\u10d4\u10dc\u10d4\u10d1\u10d7 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10e1",
        "items": {
          "provide": "\u10e1\u10d4\u10e0\u10d5\u10d8\u10e1\u10d8\u10e1 \u10e3\u10d6\u10e0\u10e3\u10dc\u10d5\u10d4\u10da\u10e1\u10d0\u10e7\u10dd\u10e4\u10d0\u10d3, \u10db\u10d0\u10d7 \u10e8\u10dd\u10e0\u10d8\u10e1 \u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10d2\u10d0\u10db\u10dd\u10e5\u10d5\u10d4\u10e7\u10dc\u10d4\u10d1\u10e3\u10da\u10d8 \u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d4\u10d1\u10d8\u10e1 \u10e9\u10d5\u10d4\u10dc\u10d4\u10d1\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1.",
          "authenticate": "\u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10d5\u10d8\u10dc\u10d0\u10dd\u10d1\u10d8\u10e1 \u10d3\u10d0\u10d3\u10d0\u10e1\u10e2\u10e3\u10e0\u10d4\u10d1\u10d8\u10e1\u10d0 \u10d3\u10d0 \u10d0\u10dc\u10d2\u10d0\u10e0\u10d8\u10e8\u10d8\u10e1 \u10db\u10d0\u10e0\u10d7\u10d5\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1.",
          "improve": "\u10e1\u10d4\u10e0\u10d5\u10d8\u10e1\u10d8\u10e1 \u10db\u10e3\u10e8\u10d0\u10dd\u10d1\u10d8\u10e1\u10d0 \u10d3\u10d0 \u10e3\u10e1\u10d0\u10e4\u10e0\u10d7\u10ee\u10dd\u10d4\u10d1\u10d8\u10e1 \u10db\u10dd\u10dc\u10d8\u10e2\u10dd\u10e0\u10d8\u10dc\u10d2\u10d8\u10e1\u10d0 \u10d3\u10d0 \u10d2\u10d0\u10e3\u10db\u10ef\u10dd\u10d1\u10d4\u10e1\u10d4\u10d1\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1."
        }
      },
      "thirdParty": {
        "title": "\u10db\u10d4\u10e1\u10d0\u10db\u10d4 \u10db\u10ee\u10d0\u10e0\u10d8\u10e1 \u10e1\u10d4\u10e0\u10d5\u10d8\u10e1\u10d4\u10d1\u10d8",
        "body": "\u10e9\u10d5\u10d4\u10dc \u10d5\u10d8\u10e7\u10d4\u10dc\u10d4\u10d1\u10d7 Keycloak-\u10e1 \u10d0\u10d5\u10d7\u10d4\u10dc\u10e2\u10d8\u10e4\u10d8\u10d9\u10d0\u10ea\u10d8\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1. \u10d7\u10e3 Google-\u10d8\u10d7 \u10d0\u10dc Facebook-\u10d8\u10d7 \u10e8\u10d4\u10ee\u10d5\u10d0\u10da\u10d7, \u10db\u10d0\u10d7\u10d8 \u10e8\u10d4\u10e1\u10d0\u10d1\u10d0\u10db\u10d8\u10e1\u10d8 \u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d8\u10e1 \u10de\u10dd\u10da\u10d8\u10e2\u10d8\u10d9\u10d4\u10d1\u10d8 \u10d5\u10e0\u10ea\u10d4\u10da\u10d3\u10d4\u10d1\u10d0 \u10db\u10d0\u10d7 \u10db\u10d8\u10d4\u10e0 \u10d3\u10d0\u10db\u10e3\u10e8\u10d0\u10d5\u10d4\u10d1\u10e3\u10da \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10d6\u10d4. \u10e9\u10d5\u10d4\u10dc \u10db\u10ee\u10dd\u10da\u10dd\u10d3 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 \u10e1\u10d0\u10ee\u10d4\u10da\u10e1\u10d0 \u10d3\u10d0 \u10d4\u10da\u10e4\u10dd\u10e1\u10e2\u10d0\u10e1 \u10d5\u10d8\u10e6\u10d4\u10d1\u10d7 \u10d0\u10db \u10de\u10e0\u10dd\u10d5\u10d0\u10d8\u10d3\u10d4\u10e0\u10d4\u10d1\u10d8\u10e1\u10d2\u10d0\u10dc. \u10e9\u10d5\u10d4\u10dc \u10d0\u10e0 \u10d5\u10e7\u10d8\u10d3\u10d8\u10d7 \u10d3\u10d0 \u10d0\u10e0 \u10d5\u10d0\u10d6\u10d8\u10d0\u10e0\u10d4\u10d1\u10d7 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 \u10de\u10d4\u10e0\u10e1\u10dd\u10dc\u10d0\u10da\u10e3\u10e0 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10e1 \u10db\u10d4\u10e1\u10d0\u10db\u10d4 \u10db\u10ee\u10d0\u10e0\u10d4\u10d4\u10d1\u10d7\u10d0\u10dc \u10e1\u10d0\u10e0\u10d4\u10d9\u10da\u10d0\u10db\u10dd \u10db\u10d8\u10d6\u10dc\u10d4\u10d1\u10d8\u10d7."
      },
      "cookies": {
        "title": "Cookie-\u10d4\u10d1\u10d8",
        "body": "\u10e9\u10d5\u10d4\u10dc \u10d5\u10d8\u10e7\u10d4\u10dc\u10d4\u10d1\u10d7 \u10db\u10ee\u10dd\u10da\u10dd\u10d3 \u10d0\u10e3\u10ea\u10d8\u10da\u10d4\u10d1\u10d4\u10da \u10e1\u10d4\u10e1\u10d8\u10d8\u10e1 cookie-\u10d4\u10d1\u10e1, \u10e0\u10dd\u10db\u10d4\u10da\u10d8\u10ea \u10e1\u10d0\u10ed\u10d8\u10e0\u10dd\u10d0 \u10d0\u10d5\u10d7\u10d4\u10dc\u10e2\u10d8\u10e4\u10d8\u10d9\u10d0\u10ea\u10d8\u10d8\u10e1\u10d0 \u10d3\u10d0 \u10e1\u10d4\u10e1\u10d8\u10d8\u10e1 \u10db\u10d0\u10e0\u10d7\u10d5\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1. \u10e9\u10d5\u10d4\u10dc \u10d0\u10e0 \u10d5\u10d8\u10e7\u10d4\u10dc\u10d4\u10d1\u10d7 \u10d7\u10d5\u10d0\u10da\u10d7\u10d5\u10d0\u10da\u10d8\u10e1 \u10d0\u10dc \u10e1\u10d0\u10e0\u10d4\u10d9\u10da\u10d0\u10db\u10dd cookie-\u10d4\u10d1\u10e1."
      },
      "rights": {
        "title": "\u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10e3\u10e4\u10da\u10d4\u10d1\u10d4\u10d1\u10d8",
        "body": "\u10d7\u10e5\u10d5\u10d4\u10dc \u10e8\u10d4\u10d2\u10d8\u10eb\u10da\u10d8\u10d0\u10d7 \u10dc\u10d4\u10d1\u10d8\u10e1\u10db\u10d8\u10d4\u10e0 \u10d3\u10e0\u10dd\u10e1 \u10dc\u10d0\u10ee\u10dd\u10d7, \u10e8\u10d4\u10d0\u10e1\u10ec\u10dd\u10e0\u10dd\u10d7 \u10d0\u10dc \u10ec\u10d0\u10e8\u10d0\u10da\u10dd\u10d7 \u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10db\u10d8\u10db\u10dd\u10ee\u10d8\u10da\u10d5\u10d4\u10d1\u10d8 \u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d0\u10d5\u10d8 \u10d3\u10d0\u10e4\u10d8\u10d3\u10d0\u10dc. \u10d0\u10dc\u10d2\u10d0\u10e0\u10d8\u10e8\u10d8\u10e1 \u10ec\u10d0\u10e1\u10d0\u10e8\u10da\u10d4\u10da\u10d0\u10d3 \u10d0\u10dc \u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10db\u10dd\u10dc\u10d0\u10ea\u10d4\u10db\u10d4\u10d1\u10d8\u10e1 \u10d0\u10e1\u10da\u10d8\u10e1 \u10db\u10dd\u10e1\u10d0\u10d7\u10ee\u10dd\u10d5\u10d0\u10d3, \u10d2\u10d7\u10ee\u10dd\u10d5\u10d7 \u10d3\u10d0\u10d2\u10d5\u10d8\u10d9\u10d0\u10d5\u10e8\u10d8\u10e0\u10d3\u10d4\u10d7 \u10e5\u10d5\u10d4\u10db\u10dd\u10d7 \u10db\u10dd\u10ea\u10d4\u10db\u10e3\u10da\u10d8 \u10e1\u10d0\u10d9\u10dd\u10dc\u10e2\u10d0\u10e5\u10e2\u10dd \u10d8\u10dc\u10e4\u10dd\u10e0\u10db\u10d0\u10ea\u10d8\u10d8\u10d7."
      },
      "contact": {
        "title": "\u10d9\u10dd\u10dc\u10e2\u10d0\u10e5\u10e2\u10d8",
        "body": "\u10d9\u10dd\u10dc\u10e4\u10d8\u10d3\u10d4\u10dc\u10ea\u10d8\u10d0\u10da\u10e3\u10e0\u10dd\u10d1\u10d0\u10e1\u10d7\u10d0\u10dc \u10d3\u10d0\u10d9\u10d0\u10d5\u10e8\u10d8\u10e0\u10d4\u10d1\u10e3\u10da\u10d8 \u10e8\u10d4\u10d9\u10d8\u10d7\u10ee\u10d5\u10d4\u10d1\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1 \u10d3\u10d0\u10d2\u10d5\u10d8\u10d9\u10d0\u10d5\u10e8\u10d8\u10e0\u10d3\u10d4\u10d7 \u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d6\u10d4: noreply@bookreview.ge."
      }
